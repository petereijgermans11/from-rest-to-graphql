{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "dj-console-ui": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "dj-console-ui:esbuild:production",
            "polyfills": []
          }
        },
        "serve": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "dj-console-ui:serve-original:development",
            "rebuildDelay": 0,
            "dev": true,
            "port": 4200
          }
        },
        "esbuild": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*",
                "input": "../music",
                "output": "music"
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "polyfills": [
              "es-module-shims"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve-original": {
          "builder": "@angular/build:dev-server",
          "options": {
            "proxyConfig": "proxy.conf.js",
            "allowedHosts": true,
            "host": "0.0.0.0"
          },
          "configurations": {
            "production": {
              "buildTarget": "dj-console-ui:esbuild:production"
            },
            "development": {
              "buildTarget": "dj-console-ui:esbuild:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    },
    "mfe-crowd-vote": {
      "projectType": "application",
      "root": "projects/mfe-crowd-vote",
      "sourceRoot": "projects/mfe-crowd-vote/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "mfe-crowd-vote:esbuild:production",
            "polyfills": []
          }
        },
        "serve": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "mfe-crowd-vote:serve-original:development",
            "rebuildDelay": 0,
            "dev": true,
            "port": 4201
          }
        },
        "esbuild": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/mfe-crowd-vote",
            "index": "projects/mfe-crowd-vote/src/index.html",
            "browser": "projects/mfe-crowd-vote/src/main.ts",
            "tsConfig": "projects/mfe-crowd-vote/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "styles": [
              "projects/mfe-crowd-vote/src/styles.scss"
            ],
            "polyfills": [
              "es-module-shims"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kB",
                  "maximumError": "12kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve-original": {
          "builder": "@angular/build:dev-server",
          "options": {
            "proxyConfig": "proxy.conf.js",
            "allowedHosts": true
          },
          "configurations": {
            "production": {
              "buildTarget": "mfe-crowd-vote:esbuild:production"
            },
            "development": {
              "buildTarget": "mfe-crowd-vote:esbuild:development",
              "port": 4201
            }
          },
          "defaultConfiguration": "development"
        }
      }
    },
    "mfe-spotlight": {
      "projectType": "application",
      "root": "projects/mfe-spotlight",
      "sourceRoot": "projects/mfe-spotlight/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "mfe-spotlight:esbuild:production",
            "polyfills": []
          }
        },
        "serve": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "mfe-spotlight:serve-original:development",
            "rebuildDelay": 0,
            "dev": true,
            "port": 4202
          }
        },
        "esbuild": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/mfe-spotlight",
            "index": "projects/mfe-spotlight/src/index.html",
            "browser": "projects/mfe-spotlight/src/main.ts",
            "tsConfig": "projects/mfe-spotlight/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "styles": [
              "projects/mfe-spotlight/src/styles.scss"
            ],
            "polyfills": [
              "es-module-shims"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kB",
                  "maximumError": "12kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve-original": {
          "builder": "@angular/build:dev-server",
          "options": {
            "proxyConfig": "proxy.conf.js",
            "allowedHosts": true
          },
          "configurations": {
            "production": {
              "buildTarget": "mfe-spotlight:esbuild:production"
            },
            "development": {
              "buildTarget": "mfe-spotlight:esbuild:development",
              "port": 4202
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
