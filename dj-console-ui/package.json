{
  "name": "dj-console-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:public": "ng serve --host 0.0.0.0",
    "start:mfe-crowd-vote": "ng serve mfe-crowd-vote",
    "start:mfe-spotlight": "ng serve mfe-spotlight",
    "start:all": "concurrently \"npm run start\" \"npm run start:mfe-crowd-vote\" \"npm run start:mfe-spotlight\"",
    "ngrok": "ngrok start --config \"$HOME/Library/Application Support/ngrok/ngrok.yml\" --config ngrok-dj-demo.yml.example --all",
    "ngrok:v3": "ngrok start --config \"$HOME/Library/Application Support/ngrok/ngrok.yml\" --config ngrok-dj-demo.v3.yml.example --all",
    "build": "ng build",
    "build:mfe-crowd-vote": "ng build mfe-crowd-vote",
    "build:mfe-spotlight": "ng build mfe-spotlight",
    "build:all": "ng build && ng build mfe-crowd-vote && ng build mfe-spotlight",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.5.2",
  "dependencies": {
    "@angular-architects/native-federation": "^21.2.3",
    "@angular/animations": "^21.2.6",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@apollo/client": "^4.1.6",
    "apollo-angular": "^13.0.0",
    "es-module-shims": "^2.8.0",
    "graphql": "^16.13.2",
    "graphql-ws": "^6.0.8",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^9.2.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "relay-runtime": "^20.1.1",
    "subscriptions-transport-ws": "^0.11.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
